# Telegram Bot Configuration
BOT_TOKEN=
API_ID=
API_HASH=

# Pyrogram user session used for large uploads
PYRO_SESSION_NAME=pyrogram_uploader

# Security: comma-separated Telegram user IDs. Empty means allow all users.
ALLOWED_USER_IDS=

# External tools
ARIA2_BIN=aria2c
ARIA2_RPC_HOST=127.0.0.1
ARIA2_RPC_PORT=6800
# Optional. Leave empty to let the bot generate a local daemon token.
ARIA2_RPC_SECRET=
FFMPEG_BIN=ffmpeg
# Required for hanime.tv. Use the absolute path when the bot runs under systemd/PM2.
# Common Ubuntu paths: /home/<user>/.deno/bin/deno or /home/<user>/.local/bin/deno
DENO_BIN=
SPOTDL_BIN=spotdl

# Optional link shown by /sites and the Supported Sites bot button.
SUPPORTED_SITES_URL=https://github.com/cyanologyst/Telegram-Aio-Downloader#-website-support-matrix

# The Pirate Bay API mirror
# TPB_API_URL=https://apibay.org
# Optional RARBG-style clone base URL. Default: https://rargb.to
# RARBG_BASE_URL=https://rargb.to
# Prowlarr multi-indexer search. Add indexers in Prowlarr, then paste the API key here.
PROWLARR_URL=http://127.0.0.1:9696
PROWLARR_API_KEY=
PROWLARR_SEARCH_LIMIT=20

# Runtime
APP_ENV=development
AUTO_CLEANUP_DAYS=7

# Web dashboard
WEB_DASHBOARD_ENABLE=true
WEB_DASHBOARD_HOST=127.0.0.1
WEB_DASHBOARD_PORT=8080

# Telegram mini-app
WEB_APP_ENABLE=true
WEB_APP_HOST=127.0.0.1
WEB_APP_PORT=5000
WEB_APP_URL=http://127.0.0.1:5000
# Optional fallback for mini-app settings/zip/upload when Telegram initData is missing.
# Set this to your private Telegram user ID.
MINI_APP_DEFAULT_CHAT_ID=
