# Telegram Bot Configuration
BOT_TOKEN=
API_ID=
API_HASH=

# Pyrogram user session used for large uploads
PYRO_SESSION_NAME=pyrogram_uploader

# Security: comma-separated Telegram user IDs. Empty means allow all users.
ALLOWED_USER_IDS=

# External tools
ARIA2_BIN=aria2c
ARIA2_RPC_HOST=127.0.0.1
ARIA2_RPC_PORT=6800
# Optional. Leave empty to let the bot generate a local daemon token.
ARIA2_RPC_SECRET=
FFMPEG_BIN=ffmpeg

# The Pirate Bay API mirror
# TPB_API_URL=https://apibay.org

# Runtime
APP_ENV=development
AUTO_CLEANUP_DAYS=7

# Web dashboard
WEB_DASHBOARD_ENABLE=true
WEB_DASHBOARD_HOST=127.0.0.1
WEB_DASHBOARD_PORT=8080

# Telegram mini-app
WEB_APP_ENABLE=true
WEB_APP_HOST=127.0.0.1
WEB_APP_PORT=5000
WEB_APP_URL=http://127.0.0.1:5000
